-- ==========================================
-- NEBULA HUB - BRUTE FORCE EDITION
-- INSTA STEAL: V49 FORCE RELOADED (Z)
-- SPEED: STABLE & GROUNDED
-- INF JUMP: SPACE HOLD ONLY
-- ==========================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer
local nebulaRunning = true
local originalTrans = {}

local states = {
    infJump = false, 
    speed = false, 
    noStealSlow = false,
    bodyAim = false, 
    xray = false, 
    esp = false, 
    smooth = false,
    autoHit = false 
}

-- [X-RAY ENGINE]
local function updateXray()
    task.spawn(function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if not nebulaRunning then break end
            if obj:IsA("BasePart") then
                local n = obj.Name:lower()
                local isWall = n:find("wall") or n:find("door") or n:find("base") or n:find("glass") or n:find("window") or n:find("roof")
                local isFloor = n:find("floor") or n:find("plate") or n:find("terrain") or n:find("ground")
                
                if isWall and not isFloor and not obj:IsDescendantOf(player.Character) then
                    if states.xray then
                        if not originalTrans[obj] then originalTrans[obj] = obj.Transparency end
                        obj.Transparency = 0.6
                    else
                        if originalTrans[obj] then obj.Transparency = originalTrans[obj] end
                    end
                end
            end
        end
    end)
end

-- [V49 FORCE RELOADED INSTANT STEAL]
local function instantSteal()
    task.spawn(function()
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        local objs = workspace:GetDescendants()
        for i, v in ipairs(objs) do
            if not nebulaRunning then break end
            if v:IsA("ProximityPrompt") then
                -- V49 Mantığı: Parent veya Ancestor üzerinden kontrol
                local pPart = v.Parent:IsA("BasePart") and v.Parent or v:FindFirstAncestorWhichIsA("BasePart")
                if pPart and (pPart.Position - root.Position).Magnitude < 30 then
                    -- Tüm engelleri bypass et
                    v.HoldDuration = 0
                    v.RequiresLineOfSight = false
                    v.Enabled = true
                    
                    task.spawn(function()
                        -- V49 En sağlam tetikleme yöntemleri sırasıyla:
                        v:InputHoldBegin()
                        if fireproximityprompt then fireproximityprompt(v) end
                        pcall(function() v:DoPromptActivated() end)
                        v:InputHoldEnd()
                    end)
                end
            end
            -- Kasma önleyici milisaniyelik es
            if i % 500 == 0 then RunService.Heartbeat:Wait() end
        end
    end)
end

-- [GUI DESIGN - CLASSIC NEBULA]
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "Nebula_Hub_Official"

local function createPanel(pos, title)
    local p = Instance.new("Frame", ScreenGui)
    p.Size = UDim2.new(0, 185, 0, 260); p.Position = pos; p.BackgroundColor3 = Color3.fromRGB(15, 15, 18); p.Active = true; p.Draggable = true
    Instance.new("UICorner", p); Instance.new("UIStroke", p).Color = Color3.new(1, 0, 0)
    local h = Instance.new("TextLabel", p)
    h.Size = UDim2.new(1, 0, 0, 40); h.Text = title; h.TextColor3 = Color3.new(1, 1, 1); h.Font = Enum.Font.GothamBlack; h.TextSize = 16; h.BackgroundTransparency = 1
    local sc = Instance.new("ScrollingFrame", p)
    sc.Size = UDim2.new(1, -10, 1, -50); sc.Position = UDim2.new(0, 5, 0, 45); sc.BackgroundTransparency = 1; sc.CanvasSize = UDim2.new(0, 0, 0, 350); sc.ScrollBarThickness = 0
    Instance.new("UIListLayout", sc).Padding = UDim.new(0, 5)
    return p, sc
end

local LMain, LScroll = createPanel(UDim2.new(0.4, -195, 0.4, -130), "Nebula Hub")
local RMain, RScroll = createPanel(UDim2.new(0.4, 10, 0.4, -130), "Nebula Hub")

local CloseBtn = Instance.new("TextButton", RMain)
CloseBtn.Size = UDim2.new(0, 25, 0, 25); CloseBtn.Position = UDim2.new(1, -30, 0, 8); CloseBtn.Text = "X"; CloseBtn.BackgroundColor3 = Color3.new(0.8, 0, 0); CloseBtn.TextColor3 = Color3.new(1, 1, 1); CloseBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", CloseBtn)
CloseBtn.MouseButton1Click:Connect(function() nebulaRunning = false ScreenGui:Destroy() end)

local function createBtn(t, p, sk, it)
    local b = Instance.new("TextButton", p)
    b.Size = UDim2.new(1, -10, 0, 35); b.BackgroundColor3 = Color3.fromRGB(25, 25, 30); b.Text = t; b.TextColor3 = Color3.new(1, 1, 1); b.Font = Enum.Font.GothamBold; b.TextSize = 10; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        if it then states[sk] = not states[sk] b.TextColor3 = states[sk] and Color3.new(0, 1, 0.5) or Color3.new(1, 1, 1)
        if sk == "xray" then updateXray() end else instantSteal() end
    end)
end

-- BUTTONS
createBtn("AUTO HIT", LScroll, "autoHit", true)
createBtn("INF JUMP (SPACE)", LScroll, "infJump", true)
createBtn("SPEED (29.5)", LScroll, "speed", true)
createBtn("NO STEAL SPEED (60)", LScroll, "noStealSlow", true)
createBtn("INSTANT STEAL (Z)", LScroll, nil, false)
createBtn("XRAY SMART", RScroll, "xray", true)
createBtn("SMOOTH FOLLOW", RScroll, "smooth", true)
createBtn("AIMBOT (BODY)", RScroll, "bodyAim", true)
createBtn("PLAYER ESP", RScroll, "esp", true)

-- [PHYSICS ENGINE]
RunService.Stepped:Connect(function()
    if not nebulaRunning or not player.Character then return end
    local r = player.Character:FindFirstChild("HumanoidRootPart")
    local h = player.Character:FindFirstChildOfClass("Humanoid")
    if not r or not h then return end

    -- INF JUMP
    if states.infJump and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        r.Velocity = Vector3.new(r.Velocity.X, 50, r.Velocity.Z)
    end

    -- STABLE SPEED
    local targetS = 0
    if states.noStealSlow then targetS = 60 elseif states.speed then targetS = 29.5 end
    
    if targetS > 0 and h.MoveDirection.Magnitude > 0 then
        local moveVec = h.MoveDirection * targetS
        r.Velocity = Vector3.new(moveVec.X, r.Velocity.Y, moveVec.Z)
    end

    -- AIM & FOLLOW
    local target = nil; local dist = 600
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local d = (p.Character.HumanoidRootPart.Position - r.Position).Magnitude
            if d < dist then dist = d; target = p.Character.HumanoidRootPart end
        end
    end

    if target then
        if states.bodyAim then
            r.CFrame = CFrame.lookAt(r.Position, Vector3.new(target.Position.X, r.Position.Y, target.Position.Z))
        end
        if states.smooth and dist > 2 then
            r.Velocity = (target.Position - r.Position).Unit * 50
        end
    end
end)

-- [AUTO HIT]
task.spawn(function()
    while nebulaRunning do
        if states.autoHit and player.Character then
            local t = player.Character:FindFirstChildOfClass("Tool")
            if t then t:Activate() end
        end
        task.wait(0.05)
    end
end)

-- [KEYBINDS]
UserInputService.InputBegan:Connect(function(i, g)
    if not g then
        if i.KeyCode == Enum.KeyCode.Insert then LMain.Visible = not LMain.Visible RMain.Visible = LMain.Visible 
        elseif i.KeyCode == Enum.KeyCode.Z then instantSteal() end
    end
end)
